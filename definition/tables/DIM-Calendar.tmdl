	partition DIM-Calendar = calculated
		mode: import
		source = ```
				
				ADDCOLUMNS(
				    CALENDARAUTO(),
				    "Année", YEAR([Date]),
				    "Mois", FORMAT([Date], "MMMM"),
				    "Numéro Mois", MONTH([Date]),
				    "Trimestre", "T" & FORMAT([Date], "Q")
				)
				
				```

	annotation PBI_Id = f2d119a3745443189815655cd004b347

